# ─────────────────────────────────────────────────────────────
# docker-compose 전용 (.env로 복사 → docker compose up -d --build)
# compose가 읽어 백엔드 environment + 프론트 build args로 전달한다.
# 로컬 도커 실행·EC2 배포 모두 이 파일을 사용.
# ─────────────────────────────────────────────────────────────

# ── DB (MySQL) ──
DB_NAME=devlearn_p3
DB_PASSWORD=change-me-strong-password

# ── 백엔드 보안/인증 ──
# JWT (256bit 이상 base64. openssl rand -base64 48 권장)
JWT_SECRET_KEY=replace-with-base64-256bit-secret
# 프론트 접속 주소(=CORS 허용 origin). 콤마 구분. 예: http://13.124.xxx.xxx
CORS_ALLOWED_ORIGINS=http://YOUR_EC2_PUBLIC_IP
# 운영은 false
SWAGGER_ENABLED=false

# ── 관리자 부트스트랩 ──
# ADMIN_PASSWORD 비우면 관리자 계정 자동 생성 안 함
ADMIN_USERNAME=admin01
ADMIN_PASSWORD=change-me-admin-password

# ── 알림 ──
# DISCORD_WEBHOOK_URL 미설정 시 로그 fallback
NOTIFICATION_CHANNEL=DISCORD
DISCORD_WEBHOOK_URL=
NOTIFICATION_DISPATCH_INTERVAL_MS=15000

# ── 결제 (Toss Payments) ──
# 키 미설정 시 모의 결제(Mock)로 동작.
TOSS_SECRET_KEY=                # 백엔드 시크릿키 (test_sk_... / live_sk_...)
VITE_TOSS_CLIENT_KEY=           # 프론트 클라이언트키 (test_ck_... / live_ck_...) — 빌드 시 주입

# ── 프론트 빌드 변수 ──
# API 주소 — EC2 퍼블릭 IP로 교체. 예: http://13.124.xxx.xxx:8080/api
VITE_API_URL=http://YOUR_EC2_PUBLIC_IP:8080/api

# ── 런타임 튜닝 ──
# JVM 힙 (t3.small 이하면 -Xmx384m 정도로)
JAVA_OPTS=-Xms256m -Xmx512m
