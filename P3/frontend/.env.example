# 로컬 프론트 실행용 (npm run dev → frontend/.env[.local] 로 읽힘)
# 이 파일을 frontend/.env 로 복사. VITE_ 접두사 변수만 클라이언트에 노출됨.

# 백엔드 API 주소 (미설정 시 /api)
VITE_API_URL=http://localhost:8080/api

# Toss Payments 클라이언트키 (test_ck_... / live_ck_...)
# 공개 키이므로 프론트 노출 정상. 비우면 모의 결제 버튼으로 동작.
# ⚠ 시크릿키(TOSS_SECRET_KEY)는 절대 여기 넣지 말 것 — 백엔드 전용.
VITE_TOSS_CLIENT_KEY=
