# ─────────────────────────────────────────────────────────────
# 로컬 프론트 실행 전용 (frontend/.env로 복사 → npm run dev)
# Vite는 VITE_ 접두사 변수만 클라이언트 번들에 노출한다.
# ⚠ 시크릿(TOSS_SECRET_KEY 등)은 절대 여기 두지 말 것 — 백엔드 전용.
# ─────────────────────────────────────────────────────────────

# ── API ──
# 백엔드 주소 (미설정 시 /api)
VITE_API_URL=http://localhost:8080/api

# ── 결제 (Toss Payments) ──
# 클라이언트키 (test_ck_... / live_ck_...). 공개 키라 프론트 노출 정상.
# 비우면 모의 결제 버튼으로 동작.
VITE_TOSS_CLIENT_KEY=
