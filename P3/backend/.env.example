# ─────────────────────────────────────────────────────────────
# 로컬 백엔드 실행 전용 (backend/.env로 복사 → cd backend && ./gradlew bootRun)
# spring.config.import=optional:file:.env 로 읽힌다. 백엔드 변수만.
# (VITE_* 는 프론트 전용이므로 여기 두지 않는다)
# ─────────────────────────────────────────────────────────────

PORT=8080
SWAGGER_ENABLED=false

# ── DB (MySQL) ──
DB_HOST=localhost
DB_PORT=3306
DB_NAME=devlearn_p3
DB_USERNAME=root
DB_PASSWORD=1234

# ── 보안/인증 ──
# JWT (256bit 이상 base64 권장)
JWT_SECRET_KEY=jwt_secret_key
# 프론트 dev 주소
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── 관리자 부트스트랩 ──
# ADMIN_PASSWORD 비우면 자동 생성 안 함
ADMIN_USERNAME=admin01
ADMIN_PASSWORD=

# ── 알림 ──
# DISCORD_WEBHOOK_URL 미설정 시 로그 fallback
NOTIFICATION_CHANNEL=DISCORD
DISCORD_WEBHOOK_URL=
NOTIFICATION_DISPATCH_INTERVAL_MS=15000

# ── 결제 (Toss Payments) ──
# 백엔드는 시크릿키만 사용. 비우면 모의 결제(Mock)로 동작.
TOSS_SECRET_KEY=
