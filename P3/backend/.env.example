# 로컬 백엔드 실행용 (cd backend && ./gradlew bootRun → backend/.env 로 읽힘)
# 이 파일을 backend/.env 로 복사해 값 채우기.

PORT=8080
SWAGGER_ENABLED=false

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=devlearn_p3
DB_USERNAME=root
DB_PASSWORD=1234

# JWT (256bit 이상 base64 권장)
JWT_SECRET_KEY=jwt_secret_key

# CORS (프론트 dev 주소)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# 관리자 부트스트랩 (P3). ADMIN_PASSWORD 비우면 자동 생성 안 함.
ADMIN_USERNAME=admin01
ADMIN_PASSWORD=

# 알림 (P3). DISCORD_WEBHOOK_URL 미설정 시 로그 fallback.
NOTIFICATION_CHANNEL=DISCORD
DISCORD_WEBHOOK_URL=
NOTIFICATION_DISPATCH_INTERVAL_MS=15000

# 결제 (P3) — Toss Payments 시크릿키. 비우면 모의 결제(Mock)로 동작.
# 백엔드는 secret key만 사용 (client key는 프론트 전용)
TOSS_SECRET_KEY=
