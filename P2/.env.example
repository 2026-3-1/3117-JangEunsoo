# EC2 배포용 환경변수. 실제 값으로 채워서 .env로 저장 후 docker compose up.

# MySQL
DB_NAME=devlearn_p2
DB_PASSWORD=change-me-strong-password

# JWT (256bit 이상 base64. openssl rand -base64 48 로 생성 권장)
JWT_SECRET_KEY=replace-with-base64-256bit-secret

# Swagger UI 노출 여부 (운영은 false)
SWAGGER_ENABLED=false

# 프론트 빌드 시 박히는 API 주소 — EC2 퍼블릭 IP로 교체
# 예: http://13.124.xxx.xxx:8080/api
VITE_API_URL=http://YOUR_EC2_PUBLIC_IP:8080/api

# JVM 힙 (t3.small 이하면 -Xmx384m 정도로 줄이기)
JAVA_OPTS=-Xms256m -Xmx512m
